@model SEINMX.Models.Directorio.ProveedorBuscadorViewModel

@{
    ViewData["Title"] = "Proveedores";

    var labelAtt = new
    {
        @@class = "form-label"
    };
    var buscadorAtt = new
    {
        htmlAttributes = new
        {
            @@class = "form-control", placeholder = "Buscar..."
        }
    };
}

@section Styles {
    <link rel="stylesheet" href="~/datatables/css/datatables.min.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/css/datatables-cb.css" asp-append-version="true"/>
}

<div class="container-fluid mt-4 px-sm-0">

    @* ── Panel de filtros server-side (GET) ── *@
    <div class="card card-outline card-secondary mb-3">
        <div class="card-header">
            <h3 class="card-title"><i class="fa-solid fa-filter me-1"></i>Filtros</h3>
            <div class="card-tools">
                <button type="button" class="btn btn-tool" data-lte-toggle="card-collapse">
                    <i class="fa-solid fa-minus"></i>
                </button>
            </div>
        </div>
        <div class="card-body">
            <form method="get" class="row g-3 align-items-end">

                <div class="col-md-3">
                    @Html.LabelFor(model => model.IdProveedor, labelAtt)
                    @Html.EditorFor(model => model.IdProveedor, buscadorAtt)
                </div>

                <div class="col-md-4">
                    @Html.LabelFor(model => model.Nombre, labelAtt)
                    @Html.EditorFor(model => model.Nombre, buscadorAtt)
                </div>

                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="fas fa-search me-1"></i>Buscar
                    </button>
                </div>
            </form>
        </div>
    </div>

    @* ── Barra de acciones ── *@
    <div class="card mb-2">
        <div class="card-body py-2 px-3">
            <button class="btn btn-primary btn-sm"
                    onclick="location.href='@Url.Action("Crear", "Proveedor")'">
                <i class="fas fa-plus me-1"></i>Agregar Proveedor
            </button>
        </div>
    </div>

    @* ── Tabla ── *@
    <div class="card shadow-sm">
        <div class="card-body p-0">

            @* ── Barra de herramientas: título izq · controles der ── *@
            <div class="d-flex justify-content-between align-items-center px-3 py-2 border-bottom">
                <span class="fw-semibold text-secondary small">
                    <i class="fa-solid fa-building-user me-1"></i>Lista de Proveedores
                    <span class="badge bg-secondary ms-1">@Model.Proveedors.Count()</span>
                </span>
                <partial name="_TablaControles" view-data='@(new ViewDataDictionary(ViewData) {
                    { "TablaSelector", "#tablaProveedores" },
                    { "NombreCsv",     "proveedores.csv"  },
                    { "Motor",         "datatables"       }
                })' />
            </div>

            <div class="table-responsive">
                <table id="tablaProveedores"
                       class="table table-sm table-striped table-hover table-bordered align-middle w-100"
                       data-cb-persistencia="Directorio_tablaProveedores_20260602">
                    <thead class="table-dark">
                    <tr>
                        <th><i class="fas fa-passport me-1"></i># Proveedor</th>
                        <th><i class="fas fa-id-card me-1"></i>Nombre</th>
                        <th><i class="fas fa-tag me-1"></i>Tarifa</th>
                        <th><i class="fas fa-tag me-1"></i>Ganancia</th>
                        <th class="text-center"><i class="fas fa-gear me-1"></i>Opciones</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in Model.Proveedors)
                    {
                        <tr data-id-proveedor="@item.IdProveedor">
                            <td>@item.IdProveedor</td>
                            <td>@item.Nombre</td>
                            <td>@item.Tarifa</td>
                            <td>@item.TarifaGanancia</td>
                            <td class="text-center">
                                <button class="btn btn-sm btn-primary"
                                        onclick="location.href='@Url.Action("Editar", "Proveedor", new { id = item.IdProveedor })'">
                                    <i class="fas fa-pen-to-square"></i>
                                </button>
                                <button class="btn btn-sm btn-danger btnEliminarProveedor" title="Eliminar">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>

@section Scripts {
    <script src="~/datatables/js/datatables.min.js" asp-append-version="true"></script>
    <script src="~/js/core/datatables-cb.js" asp-append-version="true"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {

            CB_DATATABLES.crearTabla('#tablaProveedores', {
                order: [[0, 'asc']],
                columnDefs: [
                    { targets: 4, orderable: false, searchable: false, columnControl: [] }
                ]
            });

            // ── Eliminar proveedor ─────────────────────────────────────────
            document.addEventListener('click', async function (e) {
                var btnEl = e.target.closest('.btnEliminarProveedor');
                if (!btnEl) return;

                var row         = btnEl.closest('tr');
                var idProveedor = row ? row.dataset.idProveedor : null;
                if (!idProveedor) return;

                ModalConfirmacion.mostrar({
                    titulo:     'Eliminar proveedor',
                    mensaje:    '¿Deseas eliminar este proveedor? Esta acción no se puede deshacer.',
                    etiquetaOk: 'Eliminar',
                    onConfirm:  async function () {
                        await CB_BUSY.run(btnEl, async function () {
                            var res  = await fetch('/Proveedor/Eliminar/' + idProveedor, { method: 'DELETE' });
                            var json = {};
                            try { json = await res.json(); } catch (_) {}

                            if (!res.ok || json.ok === false) {
                                Notify.error(json.error ?? json.msg ?? 'Ocurrió un error al eliminar.');
                                return;
                            }

                            row.remove();
                            Notify.success('Proveedor eliminado correctamente.');
                        });
                    }
                });
            });
        });
    </script>
}

@* Modal de confirmación — requerido por ModalConfirmacion.mostrar() *@
<partial name="_ModalConfirmacion" />
