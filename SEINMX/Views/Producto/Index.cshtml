@using System.Globalization
@model SEINMX.Models.Inventario.ProductoBuscadorViewModel

@{
    ViewBag.Title = "Productos";
    CultureInfo cultureMx = new CultureInfo("es-MX");
}

@section Styles {
    <link rel="stylesheet" href="~/datatables/css/datatables.min.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/css/datatables-cb.css" asp-append-version="true"/>
}

<div class="container-fluid mt-4 px-sm-0">

    @* ── Panel de filtros server-side (GET) ── *@
    <div class="card card-outline card-secondary mb-3">
        <div class="card-header">
            <h3 class="card-title"><i class="fa-solid fa-filter me-1"></i>Filtros</h3>
            <div class="card-tools">
                <button type="button" class="btn btn-tool" data-lte-toggle="card-collapse">
                    <i class="fa-solid fa-minus"></i>
                </button>
            </div>
        </div>
        <div class="card-body">
            <form method="get" class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label form-label-sm">Código</label>
                    <input type="text" name="Codigo" class="form-control form-control-sm"
                           placeholder="Buscar..." value="@Model.Codigo">
                </div>
                <div class="col-md-6">
                    <label class="form-label form-label-sm">Descripción</label>
                    <input type="text" name="Descripcion" class="form-control form-control-sm"
                           placeholder="Buscar..." value="@Model.Descripcion">
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary btn-sm w-100">
                        <i class="fas fa-search me-1"></i>Buscar
                    </button>
                </div>
            </form>
        </div>
    </div>

    @* ── Barra de acciones ── *@
    <div class="card mb-2">
        <div class="card-body py-2 px-3">
            <button class="btn btn-primary btn-sm"
                    onclick="location.href='@Url.Action("Crear", "Producto")'">
                <i class="fas fa-plus me-1"></i>Agregar Producto
            </button>
        </div>
    </div>

    @* ── Tabla ── *@
    <div class="card shadow-sm">
        <div class="card-body p-0">

            @* ── Barra de herramientas: título izq · controles der · fondo blanco ── *@
            <div class="d-flex justify-content-between align-items-center px-3 py-2 border-bottom">
                <span class="fw-semibold text-secondary small">
                    <i class="fa-solid fa-dolly me-1"></i>Lista de Productos
                    <span class="badge bg-secondary ms-1">@Model.Productos.Count()</span>
                </span>
                <partial name="_TablaControles" view-data='@(new ViewDataDictionary(ViewData) {
                    { "TablaSelector", "#tblProductos" },
                    { "NombreCsv",     "productos.csv" },
                    { "Motor",         "datatables"    }
                })' />
            </div>

            <div class="table-responsive">
                <table id="tblProductos"
                       class="table table-sm table-striped table-hover table-bordered align-middle w-100"
                       data-cb-persistencia="Inventario_tblProductos_20260602">
                    <thead class="table-dark">
                    <tr>
                        <th><i class="fa-solid fa-barcode me-1"></i>Código</th>
                        <th><i class="fa-solid fa-barcode me-1"></i>Cód. Proveedor</th>
                        <th><i class="fa-solid fa-circle-info me-1"></i>Descripción</th>
                        <th class="text-end"><i class="fa-regular fa-money-bill-1 me-1"></i>Precio Lista</th>
                        <th><i class="fa-solid fa-dollar-sign me-1"></i>Moneda</th>
                        <th><i class="fa-solid fa-id-card-clip me-1"></i>Proveedor</th>
                        <th><i class="fa-regular fa-comment-dots me-1"></i>Observaciones</th>
                        <th class="text-center"><i class="fas fa-gear me-1"></i>Opciones</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in Model.Productos)
                    {
                        <tr data-id-producto="@item.IdProducto">
                            <td>@item.Codigo</td>
                            <td>@item.CodigoProveedor</td>
                            <td>@item.Descripcion</td>
                            <td class="text-end">@string.Format(cultureMx, "{0:C}", item.PrecioLista)</td>
                            <td>@item.Moneda</td>
                            <td>@item.Proveedor</td>
                            <td>@item.Observaciones</td>
                            <td class="text-center">
                                <button class="btn btn-sm btn-primary"
                                        onclick="location.href='@Url.Action("Editar", "Producto", new { id = item.IdProducto })'"
                                        title="Editar">
                                    <i class="fas fa-pen-to-square"></i>
                                </button>
                                <button class="btn btn-sm btn-danger btnEliminar" title="Eliminar">
                                    <i class="fa-solid fa-trash-can"></i>
                                </button>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/datatables/js/datatables.min.js" asp-append-version="true"></script>
    <script src="~/js/core/datatables-cb.js" asp-append-version="true"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {

            // ── Inicializar DataTables con la fachada CB_DATATABLES ───────────
            var tabla = CB_DATATABLES.crearTabla('#tblProductos', {
                order: [[0, 'asc']],
                columnDefs: [
                    // Columna Opciones: sin orden ni filtro ColumnControl
                    { targets: 7, orderable: false, searchable: false, columnControl: [] }
                ]
            });

            // ── Eliminar producto (lógica existente sin cambios) ──────────────
            document.addEventListener('click', async function (e) {
                var btnEl = e.target.closest('.btnEliminar');
                if (!btnEl) return;

                var row        = btnEl.closest('tr');
                var idProducto = row ? row.dataset.idProducto : null;
                if (!idProducto) return;

                // Confirmación con ModalConfirmacion (core)
                ModalConfirmacion.mostrar({
                    titulo:     'Eliminar producto',
                    mensaje:    '¿Deseas eliminar este producto? Esta acción no se puede deshacer.',
                    etiquetaOk: 'Eliminar',
                    onConfirm:  async function () {
                        await CB_BUSY.run(btnEl, async function () {
                            var res  = await fetch('/Producto/Eliminar?id=' + idProducto, { method: 'DELETE' });
                            var json = {};
                            try { json = await res.json(); } catch (_) {}

                            if (!res.ok || json.ok === false) {
                                Notify.error(json.msg ?? json.mensaje ?? 'Ocurrió un error al eliminar.');
                                return;
                            }

                            // Eliminar la fila del DOM y de DataTables
                            row.remove();
                            Notify.success('Producto eliminado correctamente.');
                        });
                    }
                });
            });
        });
    </script>
}

@* Modal de confirmación — requerido por ModalConfirmacion.mostrar() *@
<partial name="_ModalConfirmacion" />
