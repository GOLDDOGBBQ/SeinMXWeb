@model SEINMX.Models.Directorio.ClienteBuscadorViewModel

@{
    ViewData["Title"] = "Clientes";

    var labelAtt = new
    {
        @@class = "form-label"
    };
    var buscadorAtt = new
    {
        htmlAttributes = new
        {
            @@class = "form-control", placeholder = "Buscar..."
        }
    };
}

@section Styles {
    <link rel="stylesheet" href="~/datatables/css/datatables.min.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/css/datatables-cb.css" asp-append-version="true"/>
}

<div class="container-fluid mt-4 px-sm-0">

    @* ── Panel de filtros server-side (GET) ── *@
    <div class="card card-outline card-secondary mb-3">
        <div class="card-header">
            <h3 class="card-title"><i class="fas fa-filter me-1"></i>Filtros</h3>
            <div class="card-tools">
                <button type="button" class="btn btn-tool" data-lte-toggle="card-collapse">
                    <i class="fa-solid fa-minus"></i>
                </button>
            </div>
        </div>
        <div class="card-body">
            <form method="get" class="row g-3 align-items-end">

                <div class="col-md-3">
                    @Html.LabelFor(model => model.IdCliente, labelAtt)
                    @Html.EditorFor(model => model.IdCliente, buscadorAtt)
                </div>

                <div class="col-md-4">
                    @Html.LabelFor(model => model.Nombre, labelAtt)
                    @Html.EditorFor(model => model.Nombre, buscadorAtt)
                </div>

                <div class="col-md-2">
                    @Html.LabelFor(model => model.IdPerfil, labelAtt)
                    @Html.DropDownListFor(
                        m => m.IdPerfil,
                        (List<SelectListItem>)ViewBag.Perfiles,
                        new { @class = "form-select", id = "IdPerfil", name = "IdPerfil" }
                    )
                </div>

                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="fas fa-search me-1"></i>Buscar
                    </button>
                </div>
            </form>
        </div>
    </div>

    @* ── Barra de acciones ── *@
    <div class="card mb-2">
        <div class="card-body py-2 px-3">
            <button class="btn btn-primary btn-sm"
                    onclick="location.href='@Url.Action("Crear", "Cliente")'">
                <i class="fas fa-plus me-1"></i>Agregar Cliente
            </button>
        </div>
    </div>

    @* ── Tabla ── *@
    <div class="card shadow-sm">
        <div class="card-body p-0">

            @* ── Barra de herramientas: título izq · controles der ── *@
            <div class="d-flex justify-content-between align-items-center px-3 py-2 border-bottom">
                <span class="fw-semibold text-secondary small">
                    <i class="fas fa-users me-1"></i>Lista de Clientes
                    <span class="badge bg-secondary ms-1">@Model.Clientes.Count()</span>
                </span>
                <partial name="_TablaControles" view-data='@(new ViewDataDictionary(ViewData) {
                    { "TablaSelector", "#tablaClientes" },
                    { "NombreCsv",     "clientes.csv"  },
                    { "Motor",         "datatables"    }
                })' />
            </div>

            <div class="table-responsive">
                <table id="tablaClientes"
                       class="table table-sm table-striped table-hover table-bordered align-middle w-100"
                       data-cb-persistencia="Directorio_tablaClientes_20260602">
                    <thead class="table-dark">
                    <tr>
                        <th><i class="fas fa-passport me-1"></i># Cliente</th>
                        <th><i class="fas fa-id-card me-1"></i>Nombre</th>
                        <th><i class="fas fa-tag me-1"></i>Perfil</th>
                        <th class="text-center"><i class="fas fa-gear me-1"></i>Opciones</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in Model.Clientes)
                    {
                        <tr data-id-cliente="@item.IdCliente">
                            <td>@item.IdCliente</td>
                            <td>@item.Nombre</td>
                            <td>@item.Perfil</td>
                            <td class="text-center">
                                <button class="btn btn-sm btn-primary"
                                        onclick="location.href='@Url.Action("Editar", "Cliente", new { id = item.IdCliente })'">
                                    <i class="fas fa-pen-to-square"></i>
                                </button>
                                <button class="btn btn-sm btn-danger btnEliminarCliente" title="Eliminar">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>

@section Scripts {
    <script src="~/datatables/js/datatables.min.js" asp-append-version="true"></script>
    <script src="~/js/core/datatables-cb.js" asp-append-version="true"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {

            var tabla = CB_DATATABLES.crearTabla('#tablaClientes', {
                order: [[0, 'asc']],
                columnDefs: [
                    { targets: 3, orderable: false, searchable: false, columnControl: [] }
                ]
            });

            // ── Eliminar cliente ──────────────────────────────────────────
            document.addEventListener('click', async function (e) {
                var btnEl = e.target.closest('.btnEliminarCliente');
                if (!btnEl) return;

                var row       = btnEl.closest('tr');
                var idCliente = row ? row.dataset.idCliente : null;
                if (!idCliente) return;

                ModalConfirmacion.mostrar({
                    titulo:     'Eliminar cliente',
                    mensaje:    '¿Deseas eliminar este cliente? Esta acción no se puede deshacer.',
                    etiquetaOk: 'Eliminar',
                    onConfirm:  async function () {
                        await CB_BUSY.run(btnEl, async function () {
                            var res  = await fetch('/Cliente/Eliminar/' + idCliente, { method: 'DELETE' });
                            var json = {};
                            try { json = await res.json(); } catch (_) {}

                            if (!res.ok || json.ok === false) {
                                Notify.error(json.error ?? json.msg ?? 'Ocurrió un error al eliminar.');
                                return;
                            }

                            row.remove();
                            Notify.success('Cliente eliminado correctamente.');
                        });
                    }
                });
            });
        });
    </script>
}

@* Modal de confirmación — requerido por ModalConfirmacion.mostrar() *@
<partial name="_ModalConfirmacion" />
