@using System.Globalization
@using SEINMX.Clases.Helpers
@model SEINMX.Models.Inventario.OrdenCompraBuscadorViewModel

@{
    ViewBag.Title = "Orden Compra";
    CultureInfo cultureMx = new CultureInfo("es-MX");

    var labelAtt = new
    {
        @@class = "form-label"
    };

    var editFilterAtt = new
    {
        htmlAttributes = new
        {
            @@class = "form-control",
            placeholder = "Buscar..."
        }
    };
}

@section Styles {
    <link rel="stylesheet" href="~/datatables/css/datatables.min.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/css/datatables-cb.css" asp-append-version="true"/>
}

<div class="container-fluid mt-4 px-sm-0">

    @* ── Panel de filtros server-side (GET) ── *@
    <div class="card card-outline card-secondary mb-3">
        <div class="card-header">
            <h3 class="card-title"><i class="fa-solid fa-filter me-1"></i>Filtros</h3>
            <div class="card-tools">
                <button type="button" class="btn btn-tool" data-lte-toggle="card-collapse">
                    <i class="fa-solid fa-minus"></i>
                </button>
            </div>
        </div>
        <div class="card-body">
            @using (Html.BeginForm("Index", "OrdenCompra", FormMethod.Get, new { @class = "row g-3 align-items-end" }))
            {
                <div class="col-md-2">
                    @Html.LabelFor(model => model.IdOrdenCompra, labelAtt)
                    @Html.EditorFor(model => model.IdOrdenCompra, editFilterAtt)
                </div>

                <div class="col-md-2">
                    @Html.LabelFor(model => model.IdCotizacion, labelAtt)
                    @Html.EditorFor(model => model.IdCotizacion, editFilterAtt)
                </div>

                <div class="col-md-3">
                    @Html.LabelFor(model => model.Cliente, labelAtt)
                    @Html.EditorFor(model => model.Cliente, editFilterAtt)
                </div>

                <div class="col-md-2">
                    <div class="form-group">
                        @Html.LabelFor(model => model.Status, labelAtt)
                        @Html.DropDownListFor(
                            m => m.Status,
                            Model.GetComboStatus(),
                            new { @class = "form-select", id = "Status", name = "Status" }
                        )
                    </div>
                </div>

                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="fas fa-search me-1"></i>Buscar
                    </button>
                </div>
            }
        </div>
    </div>

    @* ── Barra de acciones ── *@
    <div class="card mb-2">
        <div class="card-body py-2 px-3">
            <button class="btn btn-primary btn-sm"
                    onclick="location.href='@Url.Action("Nueva", "OrdenCompra")'">
                <i class="fas fa-plus me-1"></i>Agregar Orden Compra
            </button>
        </div>
    </div>

    @* ── Tabla ── *@
    <div class="card shadow-sm">
        <div class="card-body p-0">

            @* ── Barra de herramientas: título izq · controles der ── *@
            <div class="d-flex justify-content-between align-items-center px-3 py-2 border-bottom">
                <span class="fw-semibold text-secondary small">
                    <i class="fa-solid fa-bag-shopping me-1"></i>Lista de Órdenes de Compra
                    <span class="badge bg-secondary ms-1">@Model.Ordenes.Count()</span>
                </span>
                <partial name="_TablaControles" view-data='@(new ViewDataDictionary(ViewData) {
                    { "TablaSelector", "#tablaOrdenCompra"  },
                    { "NombreCsv",     "ordenes-compra.csv" },
                    { "Motor",         "datatables"         }
                })' />
            </div>

            <div class="table-responsive">
                <table id="tablaOrdenCompra"
                       class="table table-sm table-striped table-hover table-bordered align-middle w-100"
                       data-cb-persistencia="OrdenCompra_tablaOrdenCompra_20260602">
                    <thead class="table-dark">
                    <tr>
                        <th><i class="fa-regular fa-calendar me-1"></i>Fecha</th>
                        <th><i class="fa-solid fa-hashtag me-1"></i>Orden Compra</th>
                        <th><i class="fas fa-id-card me-1"></i>Cotización</th>
                        <th><i class="fas fa-user me-1"></i>Cliente</th>
                        <th><i class="fa-solid fa-building-user me-1"></i>Proveedor</th>
                        <th><i class="fas fa-tag me-1"></i>Status</th>
                        <th class="text-end"><i class="fa-regular fa-money-bill-1 me-1"></i>Sub Total</th>
                        <th class="text-end"><i class="fa-regular fa-money-bill-1 me-1"></i>IVA</th>
                        <th class="text-end"><i class="fa-regular fa-money-bill-1 me-1"></i>Total</th>
                        <th class="text-center"><i class="fas fa-gear me-1"></i>Opciones</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in Model.Ordenes)
                    {
                        <tr id="row-@item.IdOrdenCompra">
                            <td>@item.Fecha</td>
                            <td class="text-center">@item.IdOrdenCompra</td>
                            <td>@item.Cotizacion</td>
                            <td>@item.Cliente</td>
                            <td>@item.Proveedor</td>
                            <td>@Html.Raw(BadgeGenerator.Badge(item.Status, item.StatusDesc))</td>
                            <td class="text-end">@string.Format(cultureMx, "{0:C}", item.SubTotal)</td>
                            <td class="text-end">@string.Format(cultureMx, "{0:C}", item.Iva)</td>
                            <td class="text-end">@string.Format(cultureMx, "{0:C}", item.Total)</td>
                            <td class="text-center">
                                <button class="btn btn-sm btn-primary"
                                        onclick="location.href='@Url.Action("Editar", "OrdenCompra", new { id = item.IdOrdenCompra })'">
                                    <i class="fas fa-pen-to-square"></i>
                                </button>
                                <a class="OpenSideNav text-white btn btn-sm btn-secondary"
                                   href="@Url.Action("GenerarPdf", "OrdenCompra", new { id = item.IdOrdenCompra })"
                                   target="frameCB">
                                    <i class="fa-regular fa-eye"></i>
                                </a>
                                <a class="btn btn-sm btn-secondary"
                                   href="@Url.Action("GenerarPdf", "OrdenCompra", new { id = item.IdOrdenCompra, file = true })">
                                    <i class="fa-regular fa-file-pdf"></i>
                                </a>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="row">
        <div id="SideframeCB" class="sidenav col-12 col-sm-12 col-md-10 col-lg-6">
            <a class="closebtn CloseSideNav" data-itn-sidenav="SideframeCB"
               data-itn-frame="frameCB">&times;Cerrar</a>
            <iframe id="frameCB" name="frameCB" class="border-0 h-100 col-12 col-md-12 col-lg-12"></iframe>
        </div>
    </div>

</div>

@section Scripts {
    <script src="~/datatables/js/datatables.min.js" asp-append-version="true"></script>
    <script src="~/js/core/datatables-cb.js" asp-append-version="true"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            CB_DATATABLES.crearTabla('#tablaOrdenCompra', {
                order: [[0, 'desc']],
                columnDefs: [
                    { targets: 9, orderable: false, searchable: false, columnControl: [] }
                ]
            });
        });
    </script>
}
